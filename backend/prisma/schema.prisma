generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  USER
}

enum TransactionStatus {
  PENDING
  APPROVED
  FLAGGED
  BLOCKED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudAlertStatus {
  NEW
  INVESTIGATING
  DISMISSED
  RESOLVED
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGIN
  TRANSACTION_ANALYZED
  FRAUD_ALERT_CREATED
  IP_CHECKED
  ADMIN_ACTION
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true)

  transactions Transaction[]
  auditLogs    AuditLog[]
  fraudAlertStatusUpdates FraudAlert[] @relation("FraudAlertStatusUpdatedBy")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String?

  transactionRef  String            @unique
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("INR")

  senderAccount   String?
  receiverAccount String?

  ipAddress       String?
  deviceId        String?
  location        String?

  riskScore       Int               @default(0)
  riskLevel       String            @default("LOW")
  status          TransactionStatus @default(PENDING)

  ruleSignals     Json?
  apiSignals      Json?
  mlSignals       Json?

  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  fraudAlerts     FraudAlert[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([transactionRef])
  @@index([riskScore])
  @@index([status])
  @@index([ipAddress])
  @@map("transactions")
}

model FraudAlert {
  id            String        @id @default(uuid())
  transactionId String

  severity      AlertSeverity
  title         String
  message       String
  metadata      Json?

  status        FraudAlertStatus @default(NEW)
  statusUpdatedAt DateTime       @default(now())
  statusUpdatedByUserId String?
  dismissReason String?

  isResolved    Boolean       @default(false)
  resolvedAt    DateTime?

  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  statusUpdatedByUser User?   @relation("FraudAlertStatusUpdatedBy", fields: [statusUpdatedByUserId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([transactionId])
  @@index([severity])
  @@index([isResolved])
  @@index([status])
  @@map("fraud_alerts")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?

  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  metadata  Json?

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model IPReputation {
  id              String   @id @default(uuid())
  ipAddress       String   @unique

  abuseConfidence Int      @default(0)
  countryCode     String?
  city            String?
  isp             String?

  isBlacklisted   Boolean  @default(false)
  source          String?
  rawData         Json?

  lastCheckedAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ipAddress])
  @@index([abuseConfidence])
  @@index([isBlacklisted])
  @@map("ip_reputations")
}
